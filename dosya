function setYPerson(p){
  yPerson=p;
  document.getElementById('ybtn-e').className='person-btn'+(p==='e'?' active-m':'');
  document.getElementById('ybtn-k').className='person-btn'+(p==='k'?' active-f':'');
  document.getElementById('week-mode-row').style.display=p==='k'?'block':'none';
  buildYDayTabs(); buildYMeals();
}
function setWeekMode(m){
  weekMode=m;
  var nBtn=document.getElementById('wm-normal');
  var dBtn=document.getElementById('wm-detoks');
  nBtn.className='week-btn'+(m==='normal'?' active':'');
  dBtn.className='week-btn'+(m==='detoks'?' active':'');
  if(m!=='detoks'){dBtn.style.color='#9ecfdb';dBtn.style.borderColor='rgba(96,212,240,.35)';}
  else{dBtn.style.color='';dBtn.style.borderColor='';}
  buildYMeals();
}
function buildYDayTabs(){
  var tabs=document.getElementById('yDayTabs');
  tabs.innerHTML='';
  DAYS.forEach(function(d,i){
    var btn=document.createElement('button');
    var ac=yPerson==='e'?'active-m':'active-f';
    btn.className='day-tab'+(i===yDay?' '+ac:'');
    btn.textContent=d; btn.onclick=function(){yDay=i;buildYDayTabs();buildYMeals();};
    tabs.appendChild(btn);
  });
}
function buildYMeals(){
  var c=document.getElementById('yMealsContainer'); c.innerHTML='';
  var data = yPerson==='e' ? MEALS_E[yDay] : (weekMode==='detoks'?MEALS_K_DETOKS[yDay]:MEALS_K_NORMAL[yDay]);

  // kür kartı (kadın)
  if(yPerson==='k' && data.kur){
    var kc=document.createElement('div'); kc.className='kur-card';
    kc.innerHTML='<div class="kur-title">🌿 '+KUR_SABAH.title+'</div>'+
      KUR_SABAH.items.map(i=>'<div class="kur-item">· '+i+'</div>').join('')+
      '<div class="kur-sub">'+KUR_SABAH.note+'</div>';
    c.appendChild(kc);
    // Meta çayı
    var mc=document.createElement('div'); mc.className='kur-card'; mc.style.background='rgba(240,192,96,.06)'; mc.style.borderColor='rgba(240,192,96,.2)';
    mc.innerHTML='<div class="kur-title" style="color:var(--yellow)">☕ '+META_CAYI.title+'</div>'+
      META_CAYI.items.map(i=>'<div class="kur-item">· '+i+'</div>').join('')+
      '<div class="kur-sub">'+META_CAYI.note+'</div>';
    c.appendChild(mc);
  }

  data.meals.forEach(function(meal,mi){
    var card=document.createElement('div'); card.className='meal-card';
    var head=document.createElement('div'); head.className='meal-head';
    var dotColor=meal.dot||'var(--green)';
    head.innerHTML=
      '<div class="meal-dot" style="background:'+dotColor+'"></div>'+
      '<div class="meal-title-text">'+meal.title+' <span style="font-weight:400;font-size:11px;color:var(--muted)">'+meal.time+'</span></div>'+
      '<span class="meal-kcal">'+meal.kcal+' kcal</span>'+
      '<span class="meal-chev" id="ychev-'+mi+'">▾</span>';
    var body=document.createElement('div'); body.className='meal-body'; body.id='ymeal-'+mi;
    meal.items.forEach(function(item,ii){
      var key='y'+yPerson+weekMode+yDay+'m'+mi+'i'+ii;
      var eaten=eatenState[key];
      var row=document.createElement('div');
      row.className='food-row'+(eaten?' eaten':'');
      row.innerHTML='<div class="fcheck">'+(eaten?'✓':'')+'</div>'+
        '<div style="flex:1"><div class="food-name">'+item.n+'</div><div class="food-detail">'+item.d+'</div></div>'+
        '<div class="food-macro">'+item.m+'</div>';
      row.onclick=function(){
        var e=row.classList.toggle('eaten');
        row.querySelector('.fcheck').textContent=e?'✓':'';
        eatenState[key]=e; localStorage.setItem('eaten2',JSON.stringify(eatenState));
      };
      body.appendChild(row);
    });
    if(meal.note){var np=document.createElement('div');np.className='note-pill';np.innerHTML=meal.note;body.appendChild(np);}
    head.onclick=function(){
      var b=document.getElementById('ymeal-'+mi);
      var ch=document.getElementById('ychev-'+mi);
      var isOpen=b.style.display==='block';
      b.style.display=isOpen?'none':'block';
      ch.classList.toggle('open',!isOpen);
    };
    body.style.display='none';
    card.appendChild(head); card.appendChild(body); c.appendChild(card);
  });
}

