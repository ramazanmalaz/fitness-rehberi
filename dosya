  buildShop();
}

function mergeQty(a,b){
  if(a==='0'&&b==='0') return null;
  if(a==='0') return b;
  if(b==='0') return a;
  // try to merge numbers
  var na=parseFloat(a), nb=parseFloat(b);
  if(!isNaN(na)&&!isNaN(nb)){
    var unit=a.replace(/[\d.]/g,'').trim();
    return (na+nb)+unit;
  }
  return a+' + '+b;
}

function buildShop(){
  var c=document.getElementById('shopContainer'); c.innerHTML='';
  var selE=shopSel.e, selK=shopSel.k;
  if(!selE&&!selK){
    c.innerHTML='<div class="empty-shop">Kişi seçin</div>'; return;
  }
  SHOP_DATA.forEach(function(cat){
    var visItems=[];
    cat.items.forEach(function(item){
      var show=false, qty='', who='';
      if(selE&&selK){
        var merged=mergeQty(item.e,item.k);
        if(merged){show=true;qty=merged;who='b';}
      } else if(selE&&item.e!=='0'){
        show=true;qty=item.e;who='e';
      } else if(selK&&item.k!=='0'){
        show=true;qty=item.k;who='k';
      }
      if(show) visItems.push({n:item.n,qty:qty,who:who});
    });
    if(!visItems.length) return;
    var card=document.createElement('div'); card.className='shop-cat-card';
    var head=document.createElement('div'); head.className='shop-cat-head';
    head.textContent=cat.cat; card.appendChild(head);
    visItems.forEach(function(item){
      var key='shop-'+item.n;
      var got=shopGot[key];
      var row=document.createElement('div');
      row.className='shop-item'+(got?' got':'');
      var whoLabel=item.who==='b'?'İkisi':item.who==='e'?'Erkek':'Kadın';
      var whoClass=item.who==='b'?'who-b':item.who==='e'?'who-m':'who-f';
      row.innerHTML='<div class="fcheck">'+(got?'✓':'')+'</div>'+
        '<span class="shop-item-name">'+item.n+'</span>'+
        '<span class="shop-who '+whoClass+'">'+whoLabel+'</span>'+
        '<span class="shop-item-qty">'+item.qty+'</span>';
      row.onclick=function(){
        var g=row.classList.toggle('got');
        row.querySelector('.fcheck').textContent=g?'✓':'';
        shopGot[key]=g; localStorage.setItem('shop2',JSON.stringify(shopGot));
      };
      card.appendChild(row);
    });
    c.appendChild(card);
  });
}

